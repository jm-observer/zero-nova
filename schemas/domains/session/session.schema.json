{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "agentId": {
      "type": "string"
    },
    "createdAt": {
      "format": "int64",
      "type": "integer"
    },
    "id": {
      "type": "string"
    },
    "messageCount": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "title": {
      "type": [
        "string",
        "null"
      ]
    },
    "updatedAt": {
      "format": "int64",
      "type": "integer"
    }
  },
  "required": [
    "id",
    "agentId",
    "createdAt",
    "updatedAt",
    "messageCount"
  ],
  "title": "Session",
  "type": "object"
}
